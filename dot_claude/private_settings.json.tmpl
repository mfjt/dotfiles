{
  "env": {
    {{- if .is_private_env }}
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global.anthropic.claude-sonnet-4-6",
    "AWS_BEARER_TOKEN_BEDROCK": "{{ (bitwardenFields "item" "e2823052-25c8-48d6-be19-b3ab006ea096").AWS_BEARER_TOKEN_BEDROCK.value }}",
    "AWS_REGION": "us-west-2",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    {{- end }}
    "ANTHROPIC_MODEL": "opusplan",
    "CLAUDE_CODE_EFFORT_LEVEL": "auto",
    "ENABLE_TOOL_SEARCH": true
  },
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git branch)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)"
    ],
    "ask": [
      "Bash(git branch *)",
      "Bash(git commit*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git stash*)",
      "Bash(git tag*)",
      "Bash(rm *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add -u*)",
      "Bash(git add --update*)",
      "Bash(rm -fr *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.env)",
      "Read(**/*.env.*)",
      "Read(**/.ssh/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "syntaxHighlightingDisabled": false
}
